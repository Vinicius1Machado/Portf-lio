---
import "../styles/global.css";

const contact = {
  name: "Vinicius Oliveira Machado da Costa",
  location: "Brasília, DF",
  email: "viniciuscosta.machado@gmail.com",
  phone: "(61) 98583-4971",
  phoneHref: "tel:+5561985834971"
};

const emailSubject = "Contato profissional via portfólio";
const emailBody = `Olá, Vinicius.

Vi sua apresentação profissional e gostaria de conversar sobre uma oportunidade em tecnologia.`;

const gmailHref = `https://mail.google.com/mail/?view=cm&fs=1&to=${contact.email}&su=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;
const outlookHref = `https://outlook.live.com/mail/0/deeplink/compose?to=${contact.email}&subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;
const whatsappHref = `https://wa.me/+5561985834971?text=${encodeURIComponent(emailBody)}`;
const linkedinHref = "https://www.linkedin.com/messaging/compose?recipient=vin%C3%ADcius-costa-m";
const defaultMailHref = `mailto:${contact.email}?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const assetPath = (path: string) => `${basePath}${path.replace(/^\//, "")}`;
const resumePath = assetPath("curriculo-vinicius-costa-ad.pdf");
const profileImagePath = assetPath("vinicius-profile.png");
const faviconPath = assetPath("favicon.svg");

const highlights = [
  {
    value: "3+ anos",
    label: "em dados, implantação de sistemas e automação"
  },
  {
    value: "ETL/ELT",
    label: "pipelines, integrações e migrações de larga escala"
  },
  {
    value: "SQL avançado",
    label: "Oracle, SQL Server, PostgreSQL e MySQL"
  }
];

const stack = [
  "SQL",
  "Python",
  "VBA",
  "Power BI",
  "APIs REST/SOAP",
  "JSON/XML",
  "n8n",
  "Git/GitHub",
  "IA aplicada",
  "Scrum",
  "Kanban"
];

const experiences = [
  {
    role: "Analista de Dados",
    company: "PineAxe",
    place: "Lisboa, Portugal",
    period: "10/2025 - 05/2026",
    points: [
      "Análise, tratamento e validação de dados para elevar qualidade, consistência e confiabilidade das informações.",
      "Desenvolvimento de consultas SQL para extração, transformação, cruzamento e consolidação de dados.",
      "Criação de dashboards, relatórios e indicadores em Power BI para apoio à decisão.",
      "Automação de processos analíticos com Python e manutenção de rotinas ETL/ELT com múltiplas fontes.",
      "Consumo e tratamento de dados via APIs e arquivos JSON, XML, CSV e Excel."
    ]
  },
  {
    role: "Analista de Implantação de Sistemas",
    company: "Benner Sistemas",
    place: "Brasília, DF",
    period: "09/2023 - 09/2025",
    points: [
      "Planejamento e execução de migrações massivas de dados com foco em integridade e validação com clientes.",
      "Desenvolvimento de soluções em VBA e Python para automação de processos e processamento em massa.",
      "Manipulação avançada de bancos SQL para criação de views, procedures, triggers, functions e relatórios.",
      "Mapeamento de processos de negócio em saúde suplementar, ERP, CRM e treinamento técnico de usuários."
    ]
  },
  {
    role: "Estagiário de TI",
    company: "Tribunal Regional Federal",
    place: "Brasília, DF",
    period: "02/2023 - 09/2023",
    points: [
      "Desenvolvimento de queries SQL para ETL em bancos Oracle e SQL Server.",
      "Suporte técnico especializado na resolução de problemas sistêmicos e de infraestrutura."
    ]
  }
];

const skillGroups = [
  {
    title: "Bancos de dados",
    description:
      "SQL avançado com foco em performance, modelagem operacional e manipulação de grandes volumes.",
    items: ["T-SQL", "PL/SQL", "PLpgSQL", "Oracle", "SQL Server", "PostgreSQL", "MySQL", "Índices", "Triggers"]
  },
  {
    title: "Engenharia e integração",
    description:
      "Pipelines, migrações massivas e integrações entre sistemas corporativos por APIs e arquivos.",
    items: ["ETL/ELT", "REST", "SOAP", "JSON", "XML", "CSV", "Excel", "n8n"]
  },
  {
    title: "Automação e análise",
    description:
      "Redução de tarefas manuais, criação de rotinas confiáveis e suporte a decisões com indicadores.",
    items: ["Python", "VBA", "Power BI", "Dashboards", "Relatórios", "Git/GitHub"]
  },
  {
    title: "IA e métodos",
    description:
      "Uso de IA e engenharia de prompt para ganho de produtividade técnica, anomalias e ETL.",
    items: ["IA aplicada", "Prompt Engineering", "Scrum", "Kanban", "VS Code", "MS Office"]
  }
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Apresentação profissional de Vinicius Oliveira Machado da Costa, Analista de Dados e Automação com foco em SQL, ETL/ELT, Python, Power BI e integrações."
    />
    <title>Apresentação Vinicius Costa</title>
    <meta name="application-name" content="Apresentação Vinicius Costa" />
    <link rel="icon" type="image/svg+xml" href={faviconPath} />
  </head>
  <body>
    <canvas id="space-canvas" aria-hidden="true"></canvas>

    <div class="site-shell">
      <header class="glass-nav fixed inset-x-0 top-0 z-50">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 lg:px-8">
          <a href="#inicio" class="brand-mark text-sm font-black uppercase tracking-[0.08em] text-slate-100">
            <span>VINICIUS_COSTA</span>
          </a>
          <span class="terminal-prompt hidden border-l border-cyan-400/30 pl-5 lg:inline-flex">~/portfolio/data_</span>
          <nav class="hidden items-center gap-3 text-xs font-bold uppercase text-slate-300 md:flex" aria-label="Navegação principal">
            <a class="command-pill px-4 py-2 hover:border-cyan-300/50 hover:text-cyan-100" href="#experiencia">Experiência</a>
            <a class="command-pill px-4 py-2 hover:border-cyan-300/50 hover:text-cyan-100" href="#habilidades">Skills</a>
            <a class="command-pill px-4 py-2 hover:border-cyan-300/50 hover:text-cyan-100" href="#contato">Contato</a>
          </nav>
          <a
            href={resumePath}
            download
            class="command-pill hidden px-5 py-2 text-xs font-black uppercase text-slate-100 hover:border-lime-300/60 hover:text-lime-100 sm:inline-flex"
          >
            CV.pdf
          </a>
        </div>
      </header>

      <main id="inicio">
        <section class="mx-auto grid min-h-[92svh] max-w-7xl items-center gap-12 px-5 pb-20 pt-32 lg:grid-cols-[1.02fr_0.98fr] lg:px-8 lg:pt-32">
          <div class="max-w-3xl">
            <p class="status-badge mb-8">profile online v2.4</p>
            <h1 class="terminal-title text-balance text-4xl font-black leading-[1.02] text-white sm:text-6xl lg:text-7xl">
              Vinicius Costa
              <span class="terminal-gradient">Data Engineering.</span>
            </h1>
            <p class="terminal-copy mt-8 max-w-2xl text-base leading-8 sm:text-lg">
              Analista de Dados e Automação focado em SQL, ETL/ELT, Python, Power BI e integração de sistemas para ambientes corporativos críticos.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="#email-modal"
                data-email-modal-trigger
                data-email={contact.email}
                class="command-button command-button-primary shadow-signal focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-void"
              >
                [ ENTRAR_EM_CONTATO ] &gt;
              </a>
              <a
                href={resumePath}
                download
                class="command-button command-button-secondary focus:outline-none focus:ring-2 focus:ring-amber-200 focus:ring-offset-2 focus:ring-offset-void"
              >
                &gt; download_cv
              </a>
            </div>

            <div class="mt-8 flex flex-wrap gap-3 text-xs text-slate-300">
              <span class="command-pill px-3 py-2">{contact.location}</span>
              <a
                class="command-pill px-3 py-2 hover:border-cyan-300/60 hover:text-cyan-100"
                href="#email-only-modal"
                data-email-only-modal-trigger
                data-email={contact.email}
              >
                {contact.email}
              </a>
              <a class="command-pill px-3 py-2 hover:border-cyan-300/60 hover:text-cyan-100" href="#phone-modal" data-phone-modal-trigger>
                {contact.phone}
              </a>
            </div>
          </div>

          <aside class="grid gap-5" aria-label="Foto e destaques profissionais">
            <div class="code-window">
              <div class="window-dots" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <pre><code><span class="code-key">const</span> profile = {"{"}
  name: <span class="code-value">"Vinicius Costa"</span>,
  focus: <span class="code-value">"dados + automação"</span>,
  stack: [<span class="code-value">"SQL"</span>, <span class="code-value">"Python"</span>, <span class="code-value">"Power BI"</span>],
  pipelines: <span class="code-value">"ETL/ELT"</span>,
  available: <span class="code-bool">true</span>
{"}"};</code></pre>
            </div>

            <div class="cosmic-panel grid gap-4 p-4 sm:grid-cols-[8rem_1fr] sm:items-center">
              <div class="profile-frame p-2">
                <img
                  src={profileImagePath}
                  alt="Foto profissional de Vinicius Oliveira Machado da Costa"
                  class="aspect-square w-full rounded-md object-cover"
                  loading="eager"
                />
              </div>
              <div>
                <p class="text-xl font-black text-white">{contact.name}</p>
                <p class="mt-2 leading-7 text-cyan-100">Análise de dados, migrações, BI e integrações com foco em qualidade da informação.</p>
              </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-3">
              {highlights.map((highlight) => (
                <div class="cosmic-panel p-4">
                  <strong class="block text-2xl font-black text-white">{highlight.value}</strong>
                  <span class="mt-2 block text-sm leading-6 text-slate-300">{highlight.label}</span>
                </div>
              ))}
            </div>
          </aside>
        </section>

        <section class="border-y border-slate-700/30 bg-slate-950/35 py-6">
          <div class="mx-auto flex max-w-7xl flex-wrap gap-3 px-5 lg:px-8">
            {stack.map((item) => (
              <span class="rounded-md border border-cyan-200/20 bg-slate-900/70 px-3 py-2 text-sm font-bold text-cyan-50">
                {item}
              </span>
            ))}
          </div>
        </section>

        <section id="experiencia" class="mx-auto max-w-7xl px-5 py-20 lg:px-8">
          <div class="max-w-3xl">
            <p class="section-kicker">Histórico profissional</p>
            <h2 class="mt-3 text-3xl font-black text-white sm:text-5xl">Experiência orientada a dados, automação e entrega.</h2>
            <p class="mt-5 text-lg leading-8 text-slate-300">
              Uma trajetória conectando banco de dados, sistemas corporativos, operação técnica e indicadores para transformar informação em ação.
            </p>
          </div>

          <div class="timeline-track ml-7 mt-12 grid gap-8 pl-7">
            {experiences.map((experience) => (
              <article class="timeline-item cosmic-panel p-6">
                <div class="flex flex-col gap-3 border-b border-slate-700/40 pb-5 md:flex-row md:items-start md:justify-between">
                  <div>
                    <h3 class="text-2xl font-black text-white">{experience.role}</h3>
                    <p class="mt-2 text-base font-extrabold text-cyan-100">{experience.company} | {experience.place}</p>
                  </div>
                  <span class="w-fit rounded-md border border-amber-200/30 bg-amber-200/10 px-3 py-2 text-sm font-extrabold text-amber-100">
                    {experience.period}
                  </span>
                </div>
                <ul class="mt-5 grid list-disc gap-3 pl-5 text-slate-300 marker:text-cyan-300">
                  {experience.points.map((point) => (
                    <li class="leading-7">{point}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section id="habilidades" class="bg-slate-950/40 py-20">
          <div class="mx-auto max-w-7xl px-5 lg:px-8">
            <div class="max-w-3xl">
              <p class="section-kicker">Habilidades técnicas</p>
              <h2 class="mt-3 text-3xl font-black text-white sm:text-5xl">Competências para ambientes críticos e dados em escala.</h2>
            </div>

            <div class="mt-12 grid gap-5 md:grid-cols-2">
              {skillGroups.map((group) => (
                <article class="cosmic-panel p-6">
                  <h3 class="text-2xl font-black text-white">{group.title}</h3>
                  <p class="mt-3 leading-7 text-slate-300">{group.description}</p>
                  <div class="mt-5 flex flex-wrap gap-2">
                    {group.items.map((item) => (
                      <span class="rounded-md border border-slate-600/50 bg-slate-950/55 px-3 py-2 text-sm font-bold text-slate-100">
                        {item}
                      </span>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="formacao" class="mx-auto grid max-w-7xl gap-6 px-5 py-20 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
          <div>
            <p class="section-kicker">Formação acadêmica</p>
            <h2 class="mt-3 text-3xl font-black text-white sm:text-5xl">Base acadêmica em Sistemas de Informação.</h2>
          </div>
          <div class="cosmic-panel p-6">
            <p class="text-xl font-black text-white">Bacharelado em Sistemas de Informação</p>
            <p class="mt-3 text-lg text-cyan-100">IESB | Conclusão prevista: 12/2026</p>
            <p class="mt-5 leading-8 text-slate-300">
              Formação alinhada a desenvolvimento, bancos de dados, análise de sistemas e fundamentos para atuar com tecnologia em contextos corporativos.
            </p>
          </div>
        </section>

        <section id="contato" class="border-t border-slate-700/30 bg-slate-950/50 px-5 py-16 lg:px-8">
          <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
            <div>
              <p class="section-kicker">Contato</p>
              <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Disponível para conversar sobre oportunidades em tecnologia.</h2>
              <p class="mt-4 max-w-2xl leading-8 text-slate-300">
                Interesse em desafios envolvendo dados, BI, automação, integração de sistemas e qualidade da informação.
              </p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
              <a
                href="#email-modal"
                data-email-modal-trigger
                data-email={contact.email}
                class="inline-flex min-h-12 items-center justify-center rounded-md border border-cyan-300/60 bg-cyan-300 px-5 text-sm font-black text-slate-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-void"
              >
                Entrar em contato
              </a>
              <a
                href={resumePath}
                download
                class="inline-flex min-h-12 items-center justify-center rounded-md border border-slate-500/50 bg-slate-950/40 px-5 text-sm font-extrabold text-slate-100 transition hover:border-amber-200/80 hover:text-amber-100 focus:outline-none focus:ring-2 focus:ring-amber-200 focus:ring-offset-2 focus:ring-offset-void"
              >
                Download do CV
              </a>
            </div>
          </div>
        </section>
      </main>
    </div>

    <div id="email-modal" class="fixed inset-0 z-[70] flex items-center justify-center bg-slate-950/80 p-5 opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-sm" aria-hidden="true" role="dialog">
      <div class="relative w-full max-w-md rounded-xl border border-slate-700/50 bg-slate-900 p-6 shadow-2xl scale-95 transition-transform duration-300" id="email-modal-content">
        <button id="close-email-modal" class="absolute right-4 top-4 text-slate-400 hover:text-white focus:outline-none" aria-label="Fechar">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <h3 class="text-xl font-bold text-white mb-2">Entrar em contato</h3>
        <p class="text-slate-400 text-sm mb-6">Escolha como deseja enviar sua mensagem:</p>
        
        <div class="flex flex-col gap-3">
          <a
            href={gmailHref}
            id="gmail-option"
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          >
            <svg class="w-6 h-6 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-.4 4.25l-7.07 4.42c-.32.2-.74.2-1.06 0L4.4 8.25c-.25-.16-.4-.43-.4-.72 0-.67.73-1.07 1.3-.72L12 11l6.7-4.19c.57-.35 1.3.05 1.3.72 0 .29-.15.56-.4.72z"/></svg>
            <span class="font-medium text-white">E-mail (Gmail)</span>
          </a>
          
          <a
            href={outlookHref}
            id="outlook-option"
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          >
            <svg class="w-6 h-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>
            <span class="font-medium text-white">E-mail (Outlook)</span>
          </a>

          <a
            href={whatsappHref}
            id="whatsapp-option"
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          >
            <svg class="w-6 h-6 text-emerald-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.8 3.08 1.22 4.79 1.22 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.46 14.34c-.23.64-1.34 1.23-1.85 1.34-.48.11-1.11.23-3.23-.65-2.56-1.06-4.21-3.68-4.34-3.85-.13-.17-1.04-1.38-1.04-2.63 0-1.25.65-1.88.88-2.13.23-.25.5-.32.67-.32.17 0 .34 0 .49.01.16.01.38-.06.59.44.22.52.75 1.84.82 1.98.07.14.12.31.02.53-.1.21-.15.34-.3.51-.15.17-.32.38-.45.52-.15.17-.18.34-.02.6 1.48 2.45 2.87 2.85 3.37 3.01.44.14.7.12.96-.13.26-.26.96-1.12 1.22-1.5.26-.38.52-.32.96-.15.44.17 2.8 1.32 3.28 1.56.48.24.8.38.92.59.12.21.12 1.23-.11 1.87z"/></svg>
            <span class="font-medium text-white">WhatsApp</span>
          </a>

          <a
            href={linkedinHref}
            id="linkedin-option"
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          >
            <svg class="w-6 h-6 text-sky-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            <span class="font-medium text-white">LinkedIn</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Email Only Modal -->
    <div id="email-only-modal" class="fixed inset-0 z-[70] flex items-center justify-center bg-slate-950/80 p-5 opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-sm" aria-hidden="true" role="dialog">
      <div class="relative w-full max-w-md rounded-xl border border-slate-700/50 bg-slate-900 p-6 shadow-2xl scale-95 transition-transform duration-300" id="email-only-modal-content">
        <button id="close-email-only-modal" class="absolute right-4 top-4 text-slate-400 hover:text-white focus:outline-none" aria-label="Fechar">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <h3 class="text-xl font-bold text-white mb-2">Entrar em contato por E-mail</h3>
        <p class="text-slate-400 text-sm mb-6">Escolha como deseja enviar sua mensagem:</p>
        
        <div class="flex flex-col gap-3">
          <a
            href={gmailHref}
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400 popup-link"
          >
            <svg class="w-6 h-6 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-.4 4.25l-7.07 4.42c-.32.2-.74.2-1.06 0L4.4 8.25c-.25-.16-.4-.43-.4-.72 0-.67.73-1.07 1.3-.72L12 11l6.7-4.19c.57-.35 1.3.05 1.3.72 0 .29-.15.56-.4.72z"/></svg>
            <span class="font-medium text-white">Gmail</span>
          </a>
          
          <a
            href={outlookHref}
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400 popup-link"
          >
            <svg class="w-6 h-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>
            <span class="font-medium text-white">Outlook</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Phone Modal -->
    <div id="phone-modal" class="fixed inset-0 z-[70] flex items-center justify-center bg-slate-950/80 p-5 opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-sm" aria-hidden="true" role="dialog">
      <div class="relative w-full max-w-md rounded-xl border border-slate-700/50 bg-slate-900 p-6 shadow-2xl scale-95 transition-transform duration-300" id="phone-modal-content">
        <button id="close-phone-modal" class="absolute right-4 top-4 text-slate-400 hover:text-white focus:outline-none" aria-label="Fechar">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <h3 class="text-xl font-bold text-white mb-2">Contato via Telefone</h3>
        <p class="text-slate-400 text-sm mb-6">Escolha como deseja entrar em contato:</p>
        
        <div class="flex flex-col gap-3">
          <a
            href={contact.phoneHref}
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400 close-phone-action"
          >
            <svg class="w-6 h-6 text-indigo-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span class="font-medium text-white">Ligar {contact.phone}</span>
          </a>

          <a
            href={whatsappHref}
            class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/50 p-4 transition-colors hover:border-cyan-400/50 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-cyan-400 close-phone-action"
          >
            <svg class="w-6 h-6 text-emerald-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.8 3.08 1.22 4.79 1.22 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.46 14.34c-.23.64-1.34 1.23-1.85 1.34-.48.11-1.11.23-3.23-.65-2.56-1.06-4.21-3.68-4.34-3.85-.13-.17-1.04-1.38-1.04-2.63 0-1.25.65-1.88.88-2.13.23-.25.5-.32.67-.32.17 0 .34 0 .49.01.16.01.38-.06.59.44.22.52.75 1.84.82 1.98.07.14.12.31.02.53-.1.21-.15.34-.3.51-.15.17-.32.38-.45.52-.15.17-.18.34-.02.6 1.48 2.45 2.87 2.85 3.37 3.01.44.14.7.12.96-.13.26-.26.96-1.12 1.22-1.5.26-.38.52-.32.96-.15.44.17 2.8 1.32 3.28 1.56.48.24.8.38.92.59.12.21.12 1.23-.11 1.87z"/></svg>
            <span class="font-medium text-white">WhatsApp</span>
          </a>
        </div>
      </div>
    </div>

    <p
      id="email-feedback"
      class="pointer-events-none fixed bottom-5 left-1/2 z-[60] -translate-x-1/2 rounded-md border border-cyan-200/40 bg-slate-950/95 px-4 py-3 text-center text-sm font-bold text-cyan-50 opacity-0 shadow-signal transition"
      role="status"
      aria-live="polite"
    >
      E-mail copiado. Se o aplicativo de e-mail não abrir, cole o endereço onde preferir.
    </p>

    <script>
      const emailFeedback = document.querySelector<HTMLElement>("#email-feedback");
      let feedbackTimeout: number | undefined;

      const showEmailFeedback = () => {
        if (!emailFeedback) return;
        emailFeedback.classList.remove("opacity-0");
        emailFeedback.classList.add("opacity-100");
        window.clearTimeout(feedbackTimeout);
        feedbackTimeout = window.setTimeout(() => {
          emailFeedback.classList.remove("opacity-100");
          emailFeedback.classList.add("opacity-0");
        }, 4200);
      };

      const setupModal = (modalId: string, triggerAttr: string) => {
        const triggers = document.querySelectorAll<HTMLAnchorElement>(`[${triggerAttr}]`);
        const modal = document.getElementById(modalId);
        const modalContent = document.getElementById(`${modalId}-content`);
        const closeBtn = document.getElementById(`close-${modalId}`);

        const open = () => {
          if (!modal || !modalContent) return;
          modal.classList.remove("opacity-0", "pointer-events-none");
          modalContent.classList.remove("scale-95");
          modalContent.classList.add("scale-100");
        };

        const close = () => {
          if (!modal || !modalContent) return;
          modal.classList.add("opacity-0", "pointer-events-none");
          modalContent.classList.remove("scale-100");
          modalContent.classList.add("scale-95");
        };

        triggers.forEach((trigger) => {
          trigger.addEventListener("click", (e) => {
            e.preventDefault();
            open();
            
            const email = trigger.dataset.email;
            if (email && navigator.clipboard?.writeText) {
              navigator.clipboard.writeText(email).then(showEmailFeedback).catch(showEmailFeedback);
            } else if (triggerAttr.includes("email")) {
              showEmailFeedback();
            }
          });
        });

        if (closeBtn) closeBtn.addEventListener("click", close);
        if (modal) {
          modal.addEventListener("click", (e) => {
            if (e.target === modal) close();
          });
        }

        return { close };
      };

      const mainEmailModal = setupModal("email-modal", "data-email-modal-trigger");
      const emailOnlyModal = setupModal("email-only-modal", "data-email-only-modal-trigger");
      const phoneModal = setupModal("phone-modal", "data-phone-modal-trigger");

      document.querySelectorAll('#email-modal a').forEach(link => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const width = 600;
          const height = 650;
          const left = window.screenX + (window.outerWidth - width) / 2;
          const top = window.screenY + (window.outerHeight - height) / 2;
          window.open((e.currentTarget as HTMLAnchorElement).href, "email_popup", `width=${width},height=${height},left=${left},top=${top},resizable=yes,scrollbars=yes,status=yes`);
          mainEmailModal.close();
        });
      });

      document.querySelectorAll('#email-only-modal a.popup-link').forEach(link => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const width = 600;
          const height = 650;
          const left = window.screenX + (window.outerWidth - width) / 2;
          const top = window.screenY + (window.outerHeight - height) / 2;
          window.open((e.currentTarget as HTMLAnchorElement).href, "email_popup", `width=${width},height=${height},left=${left},top=${top},resizable=yes,scrollbars=yes,status=yes`);
          emailOnlyModal.close();
        });
      });

      document.querySelectorAll('#phone-modal a.close-phone-action').forEach(link => {
        link.addEventListener("click", () => {
          phoneModal.close();
        });
      });

      const canvas = document.querySelector<HTMLCanvasElement>("#space-canvas");

      if (canvas) {
        const ctx = canvas.getContext("2d");
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

        type Star = {
          x: number;
          y: number;
          z: number;
          size: number;
          phase: number;
          speed: number;
        };

        type Asteroid = {
          x: number;
          y: number;
          r: number;
          vx: number;
          vy: number;
          spin: number;
          phase: number;
          tone: number;
          points: number[];
        };

        if (ctx) {
          let width = 0;
          let height = 0;
          let stars: Star[] = [];
          let asteroids: Asteroid[] = [];
          const pointer = {
            x: 0,
            y: 0,
            active: false
          };

          const random = (min: number, max: number) => Math.random() * (max - min) + min;

          const buildAsteroid = (): Asteroid => {
            const totalPoints = Math.floor(random(7, 11));
            return {
              x: random(0, width),
              y: random(0, height),
              r: random(5, 12),
              vx: random(-0.055, 0.055),
              vy: random(0.025, 0.11),
              spin: random(-0.0024, 0.0024),
              phase: random(0, Math.PI * 2),
              tone: random(185, 215),
              points: Array.from({ length: totalPoints }, () => random(0.72, 1.18))
            };
          };

          const createScene = () => {
            const density = width * height;
            const starCount = Math.min(340, Math.max(120, Math.floor(density / 5600)));
            const asteroidCount = Math.min(18, Math.max(8, Math.floor(density / 105000)));

            stars = Array.from({ length: starCount }, () => ({
              x: random(0, width),
              y: random(0, height),
              z: random(0.2, 1),
              size: random(0.45, 1.45),
              phase: random(0, Math.PI * 2),
              speed: random(0.0008, 0.0022)
            }));

            asteroids = Array.from({ length: asteroidCount }, buildAsteroid);
          };

          const resize = () => {
            const dpr = Math.min(window.devicePixelRatio || 1, 2);
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = Math.floor(width * dpr);
            canvas.height = Math.floor(height * dpr);
            canvas.style.width = `${width}px`;
            canvas.style.height = `${height}px`;
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            createScene();
          };

          const drawAsteroid = (asteroid: Asteroid, time: number) => {
            const targetX = pointer.active ? pointer.x : width * 0.5;
            const targetY = pointer.active ? pointer.y : height * 0.42;
            const dx = asteroid.x - targetX;
            const dy = asteroid.y - targetY;
            const distance = Math.hypot(dx, dy);

            if (pointer.active && distance < 170) {
              const force = (170 - distance) / 170;
              asteroid.x += (dx / Math.max(distance, 1)) * force * 0.8;
              asteroid.y += (dy / Math.max(distance, 1)) * force * 0.55;
            }

            if (!reduceMotion.matches) {
              asteroid.x += asteroid.vx;
              asteroid.y += asteroid.vy;
              asteroid.phase += asteroid.spin;
            }

            if (asteroid.y > height + 24) asteroid.y = -24;
            if (asteroid.x < -24) asteroid.x = width + 24;
            if (asteroid.x > width + 24) asteroid.x = -24;

            ctx.save();
            ctx.translate(asteroid.x, asteroid.y);
            ctx.rotate(asteroid.phase + time * 0.00004);
            ctx.beginPath();
            asteroid.points.forEach((point, index) => {
              const angle = (Math.PI * 2 * index) / asteroid.points.length;
              const radius = asteroid.r * point;
              const px = Math.cos(angle) * radius;
              const py = Math.sin(angle) * radius;
              if (index === 0) {
                ctx.moveTo(px, py);
              } else {
                ctx.lineTo(px, py);
              }
            });
            ctx.closePath();
            ctx.shadowColor = "rgba(103, 232, 249, 0.1)";
            ctx.shadowBlur = 8;
            ctx.fillStyle = `hsla(${asteroid.tone}, 24%, 62%, 0.25)`;
            ctx.strokeStyle = "rgba(103, 232, 249, 0.24)";
            ctx.lineWidth = 1;
            ctx.fill();
            ctx.stroke();
            ctx.restore();
          };

          const draw = (time = 0) => {
            ctx.clearRect(0, 0, width, height);

            const parallaxX = (pointer.x / Math.max(width, 1) - 0.5) * 14;
            const parallaxY = (pointer.y / Math.max(height, 1) - 0.5) * 14;

            for (const star of stars) {
              const shimmer = reduceMotion.matches ? 0.54 : 0.34 + Math.sin(time * star.speed + star.phase) * 0.2;
              const x = star.x + parallaxX * star.z;
              const y = star.y + parallaxY * star.z;

              ctx.beginPath();
              ctx.arc(x, y, star.size * star.z, 0, Math.PI * 2);
              ctx.fillStyle = `rgba(229, 237, 247, ${Math.max(0.18, shimmer)})`;
              ctx.fill();

              if (star.z > 0.82) {
                ctx.beginPath();
                ctx.moveTo(x - star.size * 2, y);
                ctx.lineTo(x + star.size * 2, y);
                ctx.strokeStyle = "rgba(103, 232, 249, 0.14)";
                ctx.lineWidth = 0.45;
                ctx.stroke();
              }
            }

            for (const asteroid of asteroids) {
              drawAsteroid(asteroid, time);
            }
          };

          const animate = (time: number) => {
            draw(time);
            if (!reduceMotion.matches) {
              window.requestAnimationFrame(animate);
            }
          };

          window.addEventListener("resize", resize);
          window.addEventListener("pointermove", (event) => {
            pointer.x = event.clientX;
            pointer.y = event.clientY;
            pointer.active = true;
            if (reduceMotion.matches) draw();
          });
          window.addEventListener("pointerleave", () => {
            pointer.active = false;
          });

          pointer.x = window.innerWidth * 0.52;
          pointer.y = window.innerHeight * 0.42;
          resize();
          animate(0);
        }
      }
    </script>
  </body>
</html>
